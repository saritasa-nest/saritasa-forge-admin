@using Saritasa.NetForge.Controls
@using Saritasa.NetForge.Domain.Entities.Options
@using Saritasa.NetForge.Extensions
@using Saritasa.NetForge.MVVM.ViewModels.EntityDetails

@inject AdminOptions AdminOptions
@inherits MvvmComponentBase<EntityDetailsViewModel>

@if (ViewModel.IsEntityExists)
{
    <PageTitle>@ViewModel.Model.PluralName</PageTitle>
    <MudBreadcrumbs Items="breadcrumbItems"></MudBreadcrumbs>
    <MudGrid>
        <MudItem xs="12">
            <MudText Typo="Typo.h4">@ViewModel.Model.PluralName</MudText>
            <MudText Typo="Typo.body1">@ViewModel.Model.Description</MudText>
        </MudItem>

        @if (ViewModel.CanAdd)
        {
            <MudItem xs="12">
                <MudButton Variant="Variant.Outlined" OnClick="@NavigateToCreation">
                    Add @ViewModel.Model.DisplayName.ToMeaningfulName()
                </MudButton>
            </MudItem>
        }

        @if (ViewModel.CanDelete)
        {
            <MudItem xs="12">
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                           OnClick="ShowBulkDeleteEntitiesConfirmationAsync"
                           Disabled="!ViewModel.SelectedEntities.Any()">
                    Bulk Delete
                </MudButton>
            </MudItem>
        }

        @if (ViewModel.Model.GlobalCustomActions.Count > 0)
        {
            <MudItem xs="12">
                <MudStack Row AlignItems="AlignItems.Center">
                    <MudText Inline="true" Align="Align.Center">Global Action:</MudText>
                    <div class="me-3">
                        <MudSelect @bind-Value="ViewModel.SelectedGlobalCustomAction" Placeholder="Action">
                            @foreach (var action in ViewModel.Model.GlobalCustomActions)
                            {
                                <MudTooltip Text="@action.Description">
                                    <MudSelectItem Value="@action.Name">@action.Name</MudSelectItem>
                                </MudTooltip>
                            }
                        </MudSelect>
                    </div>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                               OnClick="ExecuteGlobalCustomActionAsync"
                               Disabled="ViewModel.SelectedEntities.Count <= 0">
                        Execute
                    </MudButton>
                    @if (ViewModel.SelectedEntities.Count > 0)
                    {
                        <MudText Inline="true" Align="Align.Center">
                            @(ViewModel.SelectedEntities.Count) of @(ViewModel.TotalItems) selected.
                        </MudText>
                    }
                </MudStack>
            </MudItem>
        }

        @if (ViewModel.Model.CustomActions.Count > 0)
        {
            <MudItem xs="12">
                <MudStack Row AlignItems="AlignItems.Center">
                    <MudText Inline="true" Align="Align.Center">Action:</MudText>
                    <div class="me-3">
                        <MudSelect @bind-Value="ViewModel.SelectedCustomAction" Placeholder="Action">
                            @foreach (var action in ViewModel.Model.CustomActions)
                            {
                                <MudTooltip Text="@action.Description">
                                    <MudSelectItem Value="@action.Name">@action.Name</MudSelectItem>
                                </MudTooltip>
                            }
                        </MudSelect>
                    </div>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                               OnClick="ExecuteCustomActionAsync"
                               Disabled="ViewModel.SelectedEntities.Count <= 0">
                        Execute
                    </MudButton>
                    @if (ViewModel.SelectedEntities.Count > 0)
                    {
                        <MudText Inline="true" Align="Align.Center">
                            @(ViewModel.SelectedEntities.Count) of @(ViewModel.TotalItems) selected.
                        </MudText>
                    }
                </MudStack>
            </MudItem>
        }

        @if (ViewModel.IsDisplaySearchInput)
        {
            const int debounceInterval = 250;
            <MudItem xs="6">
                <MudTextField T="string"
                              @bind-Value="ViewModel.SearchString"
                              Placeholder="Search"
                              Immediate="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              DebounceInterval="debounceInterval"
                              OnDebounceIntervalElapsed="ViewModel.Search" />
            </MudItem>
        }

        @if (!ViewModel.HasProperties)
        {
            <MudItem xs="12">
                <MudText Typo="Typo.body1">This entity doesn't have configured properties to display.</MudText>
            </MudItem>
        }

        @if (ViewModel.HasProperties)
        {
            <MudItem xs="12">
                <MudDataGrid T="object" ServerData="ViewModel.LoadEntityGridDataAsync" DragDropColumnReordering="true"
                             MultiSelection="true" @bind-SelectedItems="ViewModel.SelectedEntities"
                             RowClassFunc="RowClassFunc"
                             @ref="ViewModel.DataGrid" SortMode="SortMode.Multiple"
                             @attributes="NonKeylessEntityDataGridAttributes">
                    <Columns>
                        <EntityPropertyColumns Properties="ViewModel.Model.Properties"
                                               DataGrid="ViewModel.DataGrid"
                                               CanDelete="ViewModel.CanDelete"
                                               EntityDeleteMessage="@ViewModel.Model.EntityDeleteMessage" />
                    </Columns>

                    <PagerContent>
                        <MudDataGridPager T="object" />
                    </PagerContent>
                </MudDataGrid>
            </MudItem>
        }
    </MudGrid>
}
else
{
    <NotFound />
}
